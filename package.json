{
  "name": "opencode-windsurf-auth",
  "version": "0.1.0",
  "description": "OpenCode plugin for Windsurf/Codeium authentication - use Windsurf models in OpenCode",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "grpc-wrapper.mjs"
  ],
  "packageManager": "bun@1.2.14",
  "scripts": {
    "build": "bun run tsc -p tsconfig.build.json",
    "typecheck": "bun run tsc --noEmit",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:request": "bun run tests/live/request.ts",
    "test:analyze": "bun run tests/live/analyze.ts",
    "clean": "rm -rf dist",
    "extract-models": "bun run scripts/extract-models.ts",
    "start": "bun run dist/src/server.js"
  },
  "keywords": [
    "opencode",
    "windsurf",
    "codeium",
    "cascade",
    "ai",
    "plugin",
    "authentication"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@bufbuild/protobuf": "^2.0.0",
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-web": "^2.0.0",
    "@windsurf/sdk": "file:../windsurf-sdk",
    "proper-lockfile": "^4.1.2",
    "xdg-basedir": "^5.1.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.1.21",
    "@types/bun": "^1.3.6",
    "@types/node": "^25.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
